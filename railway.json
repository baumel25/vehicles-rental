{
    "build": {
        "builder": "nixpacks",
        "buildCommand": {
            "composer": "composer install --no-dev --optimize-autoloader",
            "artisan": "php artisan optimize"
        }
    },
    "deploy": {
        "startCommand": "php artisan serve --host=0.0.0.0 --port=$PORT",
        "healthcheckPath": "/",
        "healthcheckTimeout": 100,
        "restartPolicyType": "always"
    }
}
